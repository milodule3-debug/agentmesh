# AgentMesh — API Keys
# Copy to .env and fill in. Keys already in .env if you got the final zip.

# ── Primary (you have all of these) ──────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...          # platform.deepseek.com  — orchestrator R1 + sub-agents V3
GROQ_API_KEY=gsk_...             # console.groq.com       — free, fast fallback
OPENROUTER_API_KEY=sk-or-v1-...  # openrouter.ai          — Hermes 3, 200+ models
GEMINI_API_KEY=AIzaSy...         # aistudio.google.com    — Gemini 2.0 Flash
TOGETHER_API_KEY=tp-...          # api.together.xyz       — Llama 405B, Mixtral, Qwen

# ── Memory (you have this) ────────────────────────────────────────────────────
HONCHO_API_KEY=hch-v3-...        # app.honcho.dev         — peer modeling + dialectic memory
HONCHO_WORKSPACE_ID=agentmesh

# ── Optional ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...     # console.anthropic.com  — Claude (optional)

# ── Config ────────────────────────────────────────────────────────────────────
# Which provider runs the sub-agents (orchestrator always uses deepseek-reasoner)
AGENTMESH_PROVIDER=deepseek   # deepseek | groq | openrouter | gemini | together
